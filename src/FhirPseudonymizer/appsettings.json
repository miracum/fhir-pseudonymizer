{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning",
      "AspNetCore.Authentication": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AnonymizationEngineConfigPath": "/etc/anonymization.yaml",
  "AnonymizationEngineConfigInline": "",
  "PseudonymizationService": "gPAS",
  "UseSystemTextJsonFhirSerializer": false,
  "ApiKey": "",
  "Tracing": {
    "ServiceName": "fhir-pseudonymizer",
    "Enabled": false,
    "AspNetCoreInstrumentation": {
      "RecordException": "true"
    }
  },
  "EnableMetrics": true,
  "MetricsPort": 8081,
  "Cache": {
    "SizeLimit": 2048,
    "SlidingExpirationMinutes": 5,
    "AbsoluteExpirationMinutes": 30
  },
  "gPAS": {
    "Url": "",
    "RequestRetryCount": 3,
    "Auth": {
      "Basic": {
        "Username": "",
        "Password": ""
      },
      "OAuth": {
        "TokenEndpoint": "",
        "ClientId": "",
        "ClientSecret": "",
        "Scope": "",
        "Resource": ""
      }
    },
    "Version": "1.10.1"
  },
  "Vfps": {
    "Address": "",
    "UnsafeUseInsecureChannelCallCredentials": true,
    "UseTls": false
  },
  "entici": {
    "Url": "",
    "RequestRetryCount": 3,
    "Auth": {
      "Basic": {
        "Username": "",
        "Password": ""
      },
      "OAuth": {
        "TokenEndpoint": "",
        "ClientId": "",
        "ClientSecret": "",
        "Scope": "",
        "Resource": ""
      }
    }
  },
  "Features": {
    "ConditionalReferencePseudonymization": false
  },
  "Anonymization": {
    "CryptoHashKey": "",
    "EncryptKey": "",
    "ShouldAddSecurityTag": true
  }
}
