@page "/"
@using System.IO.Compression
@using System.Text
@using System.Text.Json
@using FhirPseudonymizer.Playground
@using Microsoft.Health.Fhir.Anonymizer.Core.AnonymizerConfigurations
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>FHIR Pseudonymizer Playground</PageTitle>

<header>
  <h1>FHIR Pseudonymizer Playground</h1>
  <p>
    Try out <code>anonymization.yaml</code> rules entirely in your browser - nothing is sent to a server.
  </p>
  <p>
    ⚠️ The <code>encrypt</code> method is not supported in the playground.
  </p>
</header>

<div class="toolbar">
  <button @onclick="Run">Run</button>
  <button @onclick="Share" disabled="@_sharing">@(_sharing ? "Copied!" : "Share")</button>
  <label><input type="checkbox" @bind="prettyOutput" /> Pretty-print output</label>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
  <pre class="error">@errorMessage</pre>
}

<div class="panes">
  <section class="pane">
    <h2>Rules (anonymization.yaml)</h2>
    <textarea spellcheck="false" @bind="rulesYaml" @bind:event="oninput"></textarea>
  </section>

  <section class="pane">
    <h2>Input resource (JSON)</h2>
    <textarea spellcheck="false" @bind="inputJson" @bind:event="oninput"></textarea>
  </section>

  <section class="pane">
    <h2>Output</h2>
    <textarea spellcheck="false" readonly value="@outputJson"></textarea>
  </section>
</div>

@code {
  private string rulesYaml = DefaultRulesYaml;
  private string inputJson = DefaultInputJson;
  private string outputJson = string.Empty;
  private string errorMessage = string.Empty;
  private bool prettyOutput = true;
  private bool _sharing;

  protected override void OnInitialized()
  {
    var fragment = new Uri(Nav.Uri).Fragment.TrimStart('#');
    if (!string.IsNullOrEmpty(fragment) && TryDecodeState(fragment, out var rules, out var input))
    {
      rulesYaml = rules;
      inputJson = input;
    }
    Run();
  }

  private void Run()
  {
    errorMessage = string.Empty;
    outputJson = string.Empty;

    try
    {
      var engine = AnonymizerEngineHost.CreateFromYaml(rulesYaml);
      var settings = new AnonymizerSettings { IsPrettyOutput = prettyOutput };
      outputJson = engine.AnonymizeJsonAsync(inputJson, settings).GetAwaiter().GetResult();
    }
    catch (Exception ex)
    {
      errorMessage = ex.Message;
    }
  }

  private async Task Share()
  {
    _sharing = true;
    var hash = EncodeState(rulesYaml, inputJson);
    var shareUrl = Nav.Uri.Split('#')[0] + "#" + hash;
    await JS.InvokeVoidAsync("playground.setUrlHash", hash);
    await JS.InvokeVoidAsync("playground.copyToClipboard", shareUrl);
    StateHasChanged();
    await Task.Delay(2000);
    _sharing = false;
  }

  private static string EncodeState(string rules, string input)
  {
    var json = JsonSerializer.Serialize(new { r = rules, i = input });
    var bytes = Encoding.UTF8.GetBytes(json);
    using var ms = new MemoryStream();
    using (var deflate = new DeflateStream(ms, CompressionLevel.Optimal, leaveOpen: true))
      deflate.Write(bytes);
    return Convert.ToBase64String(ms.ToArray())
        .TrimEnd('=').Replace('+', '-').Replace('/', '_');
  }

  private static bool TryDecodeState(string encoded, out string rules, out string input)
  {
    rules = input = string.Empty;
    try
    {
      var padded = encoded.Replace('-', '+').Replace('_', '/');
      padded += (padded.Length % 4) switch { 2 => "==", 3 => "=", _ => "" };
      using var compressed = new MemoryStream(Convert.FromBase64String(padded));
      using var deflate = new DeflateStream(compressed, CompressionMode.Decompress);
      using var reader = new StreamReader(deflate, Encoding.UTF8);
      var doc = JsonDocument.Parse(reader.ReadToEnd());
      rules = doc.RootElement.GetProperty("r").GetString() ?? string.Empty;
      input = doc.RootElement.GetProperty("i").GetString() ?? string.Empty;
      return true;
    }
    catch { return false; }
  }

  private const string DefaultRulesYaml =
        """
        fhirVersion: R4
        fhirPathRules:
          - path: nodesByType('HumanName')
            method: redact
          - path: Patient.birthDate
            method: dateShift
          - path: nodesByType('Identifier').where(type.coding.where(system='http://terminology.hl7.org/CodeSystem/v2-0203' and code='MR').exists()).value
            method: pseudonymize
          - path: nodesByType('id')
            method: cryptoHash
        parameters:
          dateShiftKey: playground
          dateShiftScope: resource
          cryptoHashKey: fhir-pseudonymizer
          enablePartialAgesForRedact: false
          enablePartialDatesForRedact: false
          enablePartialZipCodesForRedact: false
          restrictedZipCodeTabulationAreas: []
        """;

  private const string DefaultInputJson =
        """
        {
          "resourceType": "Patient",
          "id": "example",
          "identifier": [
            {
              "type": {
                "coding": [
                  {
                    "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
                    "code": "MR"
                  }
                ]
              },
              "value": "12345"
            }
          ],
          "name": [
            {
              "family": "Mustermann",
              "given": ["Max"]
            }
          ],
          "gender": "male",
          "birthDate": "1980-05-12"
        }
        """;
}
