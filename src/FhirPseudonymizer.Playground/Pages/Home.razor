@page "/"
@using FhirPseudonymizer.Playground
@using Microsoft.Health.Fhir.Anonymizer.Core.AnonymizerConfigurations

<PageTitle>FHIR Pseudonymizer Playground</PageTitle>

<header>
  <h1>FHIR Pseudonymizer Playground</h1>
  <p>
    Try out <code>anonymization.yaml</code> rules entirely in your browser - nothing is sent to a server.
  </p>
</header>

<div class="toolbar">
  <button @onclick="Run">Run</button>
  <label><input type="checkbox" @bind="prettyOutput" /> Pretty-print output</label>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
  <pre class="error">@errorMessage</pre>
}

<div class="panes">
  <section class="pane">
    <h2>Rules (anonymization.yaml)</h2>
    <textarea spellcheck="false" @bind="rulesYaml" @bind:event="oninput"></textarea>
  </section>

  <section class="pane">
    <h2>Input resource (JSON)</h2>
    <textarea spellcheck="false" @bind="inputJson" @bind:event="oninput"></textarea>
  </section>

  <section class="pane">
    <h2>Output</h2>
    <textarea spellcheck="false" readonly value="@outputJson"></textarea>
  </section>
</div>

@code {
  private string rulesYaml = DefaultRulesYaml;
  private string inputJson = DefaultInputJson;
  private string outputJson = string.Empty;
  private string errorMessage = string.Empty;
  private bool prettyOutput = true;

  protected override void OnInitialized()
  {
    Run();
  }

  private void Run()
  {
    errorMessage = string.Empty;
    outputJson = string.Empty;

    try
    {
      var engine = AnonymizerEngineHost.CreateFromYaml(rulesYaml);
      var settings = new AnonymizerSettings { IsPrettyOutput = prettyOutput };
      outputJson = engine.AnonymizeJsonAsync(inputJson, settings).GetAwaiter().GetResult();
    }
    catch (Exception ex)
    {
      errorMessage = ex.Message;
    }
  }

  private const string DefaultRulesYaml =
        """
        fhirVersion: R4
        fhirPathRules:
          - path: nodesByType('HumanName')
            method: redact
          - path: Patient.birthDate
            method: dateShift
          - path: nodesByType('Identifier').where(type.coding.where(system='http://terminology.hl7.org/CodeSystem/v2-0203' and code='MR').exists()).value
            method: pseudonymize
          - path: nodesByType('id')
            method: cryptoHash
        parameters:
          dateShiftKey: playground
          dateShiftScope: resource
          cryptoHashKey: fhir-pseudonymizer
          enablePartialAgesForRedact: true
          enablePartialDatesForRedact: true
          enablePartialZipCodesForRedact: true
          restrictedZipCodeTabulationAreas: []
        """;

  private const string DefaultInputJson =
        """
        {
          "resourceType": "Patient",
          "id": "example",
          "identifier": [
            {
              "type": {
                "coding": [
                  {
                    "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
                    "code": "MR"
                  }
                ]
              },
              "value": "12345"
            }
          ],
          "name": [
            {
              "family": "Mustermann",
              "given": ["Max"]
            }
          ],
          "gender": "male",
          "birthDate": "1980-05-12"
        }
        """;
}
