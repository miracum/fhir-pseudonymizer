@page "/"
@using System.IO.Compression
@using System.Text
@using System.Text.Json
@using FhirPseudonymizer.Playground
@using Microsoft.Health.Fhir.Anonymizer.Core.AnonymizerConfigurations
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>FHIR Pseudonymizer Playground</PageTitle>

<header>
  <h1>FHIR Pseudonymizer Playground</h1>
  <p>
    Try out <code>anonymization.yaml</code> rules entirely in your browser - nothing is sent to a server.
  </p>
  <p>
    ⚠️ The <code>encrypt</code> method is not supported in the playground.
  </p>
</header>

<div class="toolbar">
  <button @onclick="RunAsync">Run</button>
  <button @onclick="Share" disabled="@_sharing">@(_sharing ? "Copied!" : "Share")</button>
  <button class="toolbar-theme" @onclick="ToggleTheme">@(_theme == "dark" ? "Light mode" : "Dark mode")</button>
  <label><input type="checkbox" @bind="prettyOutput" /> Pretty-print output</label>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
  <pre class="error">@errorMessage</pre>
}

<div class="panes">
  <section class="pane">
    <h2>Rules (anonymization.yaml)</h2>
    <div class="editor-container">
      <StandaloneCodeEditor @ref="_rulesEditor" Id="rules-editor"
        ConstructionOptions="RulesEditorOptions" />
    </div>
  </section>

  <section class="pane">
    <h2>Input resource (JSON)</h2>
    <div class="editor-container">
      <StandaloneCodeEditor @ref="_inputEditor" Id="input-editor"
        ConstructionOptions="InputEditorOptions" />
    </div>
  </section>
</div>

<section class="pane-diff">
  <h2>Diff (input → anonymized)</h2>
  <div class="editor-container editor-container-diff">
    <StandaloneDiffEditor @ref="_diffEditor" Id="diff-editor"
      ConstructionOptions="DiffEditorOptions"
      OnDidInit="DiffEditorOnDidInit" />
  </div>
</section>

@code {
  private string rulesYaml = DefaultRulesYaml;
  private string inputJson = DefaultInputJson;
  private string outputJson = string.Empty;
  private string errorMessage = string.Empty;
  private bool prettyOutput = true;
  private bool _sharing;
  private bool _diffEditorInitialized;
  private string _theme = "light";

  private StandaloneCodeEditor? _rulesEditor;
  private StandaloneCodeEditor? _inputEditor;
  private StandaloneDiffEditor? _diffEditor;

  protected override void OnInitialized()
  {
    // IJSInProcessRuntime is always available in Blazor WASM; read theme before
    // ConstructionOptions callbacks fire so editors start with the correct theme.
    if (JS is IJSInProcessRuntime syncJS)
      _theme = syncJS.Invoke<string>("playground.getTheme");

    var fragment = new Uri(Nav.Uri).Fragment.TrimStart('#');
    if (!string.IsNullOrEmpty(fragment) && TryDecodeState(fragment, out var rules, out var input))
    {
      rulesYaml = rules;
      inputJson = input;
    }
    // Compute output synchronously so DiffEditorOnDidInit can use the result
    ComputeOutput();
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (!firstRender) return;
    _theme = await JS.InvokeAsync<string>("playground.getTheme");
    StateHasChanged();
  }

  private async Task ToggleTheme()
  {
    _theme = _theme == "dark" ? "light" : "dark";
    await ApplyThemeAsync();
  }

  private async Task ApplyThemeAsync()
  {
    await JS.InvokeVoidAsync("playground.setTheme", _theme);
    if (_diffEditorInitialized)
      await BlazorMonaco.Editor.Global.SetTheme(JS, _theme == "dark" ? "vs-dark" : "vs");
  }

  private void ComputeOutput()
  {
    errorMessage = string.Empty;
    outputJson = string.Empty;
    try
    {
      var engine = AnonymizerEngineHost.CreateFromYaml(rulesYaml);
      var settings = new AnonymizerSettings { IsPrettyOutput = prettyOutput };
      outputJson = engine.AnonymizeJsonAsync(inputJson, settings).GetAwaiter().GetResult();
    }
    catch (Exception ex)
    {
      errorMessage = ex.Message;
    }
  }

  private async Task RunAsync()
  {
    if (_rulesEditor != null)
      rulesYaml = await _rulesEditor.GetValue();
    if (_inputEditor != null)
      inputJson = await _inputEditor.GetValue();

    ComputeOutput();

    if (_diffEditorInitialized && _diffEditor != null)
    {
      await _diffEditor.OriginalEditor.SetValue(inputJson);
      await _diffEditor.ModifiedEditor.SetValue(outputJson);
    }
  }

  private StandaloneEditorConstructionOptions RulesEditorOptions(StandaloneCodeEditor _) => new()
  {
    Language = "yaml",
    AutomaticLayout = true,
    Value = rulesYaml,
    Minimap = new EditorMinimapOptions { Enabled = false },
    ScrollBeyondLastLine = false,
    Theme = _theme == "dark" ? "vs-dark" : "vs",
  };

  private StandaloneEditorConstructionOptions InputEditorOptions(StandaloneCodeEditor _) => new()
  {
    Language = "json",
    AutomaticLayout = true,
    Value = inputJson,
    Minimap = new EditorMinimapOptions { Enabled = false },
    ScrollBeyondLastLine = false,
    Theme = _theme == "dark" ? "vs-dark" : "vs",
  };

  private StandaloneDiffEditorConstructionOptions DiffEditorOptions(StandaloneDiffEditor _) => new()
  {
    AutomaticLayout = true,
    OriginalEditable = false,
    ReadOnly = true,
    Theme = _theme == "dark" ? "vs-dark" : "vs",
  };

  private async Task DiffEditorOnDidInit()
  {
    _diffEditorInitialized = true;
    if (_diffEditor == null)
      return;

    var originalModel = await BlazorMonaco.Editor.Global.CreateModel(JS, inputJson, "json", "playground-original");
    var modifiedModel = await BlazorMonaco.Editor.Global.CreateModel(JS, outputJson, "json", "playground-modified");
    await _diffEditor.SetModel(new DiffEditorModel
    {
      Original = originalModel,
      Modified = modifiedModel,
    });
  }

  private async Task Share()
  {
    if (_rulesEditor != null)
      rulesYaml = await _rulesEditor.GetValue();
    if (_inputEditor != null)
      inputJson = await _inputEditor.GetValue();

    _sharing = true;
    var hash = EncodeState(rulesYaml, inputJson);
    var shareUrl = Nav.Uri.Split('#')[0] + "#" + hash;
    await JS.InvokeVoidAsync("playground.setUrlHash", hash);
    await JS.InvokeVoidAsync("playground.copyToClipboard", shareUrl);
    StateHasChanged();
    await Task.Delay(2000);
    _sharing = false;
  }

  private static string EncodeState(string rules, string input)
  {
    var json = JsonSerializer.Serialize(new { r = rules, i = input });
    var bytes = Encoding.UTF8.GetBytes(json);
    using var ms = new MemoryStream();
    using (var deflate = new DeflateStream(ms, CompressionLevel.Optimal, leaveOpen: true))
      deflate.Write(bytes);
    return Convert.ToBase64String(ms.ToArray())
        .TrimEnd('=').Replace('+', '-').Replace('/', '_');
  }

  private static bool TryDecodeState(string encoded, out string rules, out string input)
  {
    rules = input = string.Empty;
    try
    {
      var padded = encoded.Replace('-', '+').Replace('_', '/');
      padded += (padded.Length % 4) switch { 2 => "==", 3 => "=", _ => "" };
      using var compressed = new MemoryStream(Convert.FromBase64String(padded));
      using var deflate = new DeflateStream(compressed, CompressionMode.Decompress);
      using var reader = new StreamReader(deflate, Encoding.UTF8);
      var doc = JsonDocument.Parse(reader.ReadToEnd());
      rules = doc.RootElement.GetProperty("r").GetString() ?? string.Empty;
      input = doc.RootElement.GetProperty("i").GetString() ?? string.Empty;
      return true;
    }
    catch (FormatException) { return false; }
    catch (InvalidDataException) { return false; }
    catch (JsonException) { return false; }
    catch (IOException) { return false; }
  }

  private const string DefaultRulesYaml =
        """
        fhirVersion: R4
        fhirPathRules:
          - path: nodesByType('HumanName')
            method: redact
          - path: Patient.birthDate
            method: dateShift
          - path: nodesByType('Identifier').where(type.coding.where(system='http://terminology.hl7.org/CodeSystem/v2-0203' and code='MR').exists()).value
            method: pseudonymize
          - path: nodesByType('id')
            method: cryptoHash
        parameters:
          dateShiftKey: playground
          dateShiftScope: resource
          cryptoHashKey: fhir-pseudonymizer
          enablePartialAgesForRedact: false
          enablePartialDatesForRedact: false
          enablePartialZipCodesForRedact: false
          restrictedZipCodeTabulationAreas: []
        """;

  private const string DefaultInputJson =
        """
        {
          "resourceType": "Patient",
          "id": "example",
          "identifier": [
            {
              "type": {
                "coding": [
                  {
                    "system": "http://terminology.hl7.org/CodeSystem/v2-0203",
                    "code": "MR"
                  }
                ]
              },
              "value": "12345"
            }
          ],
          "name": [
            {
              "family": "Mustermann",
              "given": ["Max"]
            }
          ],
          "gender": "male",
          "birthDate": "1980-05-12"
        }
        """;
}
